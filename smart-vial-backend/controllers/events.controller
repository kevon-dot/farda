//NOT IN USE 

const Event = require('../models/Event');
const Device = require('../models/Device');

exports.logEvent = async (req, res) => {
    try {
        const { device_id, event, event_id, timestamp, payload } = req.body;

        if (event_id) {
            const existingEvent = await Event.findOne({ idempotency_key: event_id });
            if (existingEvent) {
                console.log('Duplicate event received, ignoring:', event_id);
                return res.status(200).json({ status: 'Duplicate event ignored' });
            }
        }

        if (!device_id || !event) {
            return res.status(400).json({ error: 'Bad Request: device_id and event are required' });
        }

        const newEvent = new Event({
            device_id,
            event_type: event,
            device_timestamp: timestamp ? new Date(timestamp * 1000) : null,
            server_timestamp: new Date(),
            payload: payload || {},
            idempotency_key: event_id || null
        });

        await newEvent.save();
        await Device.findOneAndUpdate(
            { device_id },
            { $set: { device_id, last_seen: new Date() } },
            { upsert: true }
        );

        res.status(200).json({ status: 'Event logged successfully' });
    } catch (err) {
        if (err.code === 11000) {
            return res.status(200).json({ status: 'Duplicate event ignored' });
        }
        console.error(err);
        res.status(500).json({ error: err.message });
    }
};