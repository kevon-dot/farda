# Example environment file. Copy to the real filename and fill in values.
# Real .env files are gitignored and MUST NOT be committed.

PORT = 5000
NODE_ENV=development



MONGO_URI=<mongo_uri>
DATABASE_URL="<database_url>"

JWT_SECRET=<jwt_secret>
JWT_EXPIRES_IN=30d


# Device API Key (for ESP32 authentication)
# Generate a strong random key for production use
DEVICE_API_KEY=<device_api_key>

CORS_ORIGINS=http://localhost:3000

RATE_LIMIT_WINDOW_MS=6000000
RATE_LIMIT_MAX_REQUESTS=100

TYME_SYNC_TOLERANCE_SECONDS=300

BETTER_AUTH_URL=https://your-host.example.com
