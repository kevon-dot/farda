# Example environment file. Copy to the real filename and fill in values.
# Real .env files are gitignored and MUST NOT be committed.

PORT = 5000
NODE_ENV=development



MONGO_URI=<mongo_uri>
DATABASE_URL="<database_url>"

JWT_SECRET=<jwt_secret>
JWT_EXPIRES_IN=30d


# DEPRECATED: legacy shared device API key. No longer used for ingestion auth
# (A3 replaced it with per-device HMAC). Kept only for backward compatibility.
DEVICE_API_KEY=<device_api_key>

# A3 — Master key used to encrypt each device's HMAC secret at rest (AES-256-GCM).
# REQUIRED in production. Generate 32 random bytes as hex, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Never commit the real value and never store it in the database.
DEVICE_SECRET_ENC_KEY=<64_char_hex_master_key>

CORS_ORIGINS=http://localhost:3000

RATE_LIMIT_WINDOW_MS=6000000
RATE_LIMIT_MAX_REQUESTS=100

# Stricter limiter for the device ingestion surface (POST /api/ingest/*)
INGEST_RATE_LIMIT_WINDOW_MS=60000
INGEST_RATE_LIMIT_MAX=120

# Stricter limiter for authenticated user/caregiver routes
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=100

# Max accepted JSON request body size
JSON_BODY_LIMIT=100kb

TYME_SYNC_TOLERANCE_SECONDS=300

BETTER_AUTH_URL=https://your-host.example.com
