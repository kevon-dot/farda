// Prisma schema for better-auth with phone number authentication
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(cuid())
  email               String?  @unique
  name                String?
  image               String?
  phoneNumber         String?  @unique
  phoneNumberVerified Boolean  @default(false)
  emailVerified       Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Reminder-delivery preferences (GTM-537). The app schedules + delivers local
  // notifications and enforces these; the backend only STORES them so a user's
  // preferences survive reinstall and feed analytics.
  //
  // IANA timezone name (e.g. "America/New_York"). Null falls back to device tz.
  timezone        String?
  // Quiet hours as minutes-from-local-midnight [0, 1440). When start/end are
  // both set, deliveries inside the window are suppressed (the app does the
  // suppression; see ReminderScheduler). A window may wrap past midnight
  // (start > end), e.g. 22:00 (1320) -> 07:00 (420).
  quietHoursStart Int?
  quietHoursEnd   Int?

  accounts               Account[]
  sessions               Session[]
  prescriptions          Prescription[]
  doses                  Dose[]
  auditLogs              AuditLog[]
  pushTokens             PushToken[]
  reminderResponseEvents ReminderResponseEvent[]
  refillEvents           RefillEvent[]
}

model Prescription {
  id                   String    @id @default(cuid())
  userId               String
  deviceId             String?   @unique // The vial ID from the external API
  rxNumber             String?
  storeNumber          String?
  pharmacyOrDoctorName String?
  contactDetails       String?
  dateFilled           DateTime?
  dateExpired          DateTime?
  address              String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Thin per-prescription reminder configuration (GTM-537). Enabled by default;
  // `times` lets a user override the schedule's default dose times. The actual
  // Dose rows remain the source of truth for WHEN; this only governs reminder
  // delivery on/off + any user-customised times. Optional one-to-one.
  reminderEnabled Boolean @default(true)
  // JSON array of "HH:mm" local times the user wants reminders at, e.g.
  // ["08:00","20:00"]. Null = derive from the dose schedule as before.
  reminderTimes   Json?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  doses        Dose[]
  medicines    Medicine[]
  refillEvents RefillEvent[]

  @@index([userId])
}

model Medicine {
  id                 String   @id @default(cuid())
  prescriptionId     String
  medicineName       String
  genericName        String?
  dosageInstructions String?
  strength           String?
  qty                String?
  frequency          String?
  refillsInfo        String?
  sideEffects        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
}

model Dose {
  id             String    @id @default(cuid())
  prescriptionId String
  userId         String
  scheduledFor   DateTime
  takenAt        DateTime?
  mood           String?
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  reminderResponseEvents ReminderResponseEvent[]

  @@index([userId])
  @@index([prescriptionId])
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  type                 String
  provider             String
  providerAccountId    String
  accessToken          String?
  refreshToken         String?
  accessTokenExpiresAt DateTime?
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Tamper-evident, append-only audit trail of PHI access (HIPAA §164.312(b)).
///
/// APPEND-ONLY: there is intentionally NO `updatedAt`. Application code must
/// NEVER UPDATE or DELETE rows in this table. Tamper-evidence comes from a
/// per-row SHA-256 hash chain: `hash = sha256(prevHash + canonical(entry))`,
/// where `prevHash` is the `hash` of the immediately-preceding row. Any
/// after-the-fact edit/removal breaks the chain and is detectable.
///
/// This row must NEVER contain PHI values: only resource ids/types/actions and
/// request metadata, so the audit trail does not itself become a PHI leak.
model AuditLog {
  id           String   @id @default(cuid())
  /// The acting session user. Nullable so system/background actions can be
  /// recorded with no actor.
  actorUserId  String?
  /// READ / CREATE / UPDATE / DELETE.
  action       String
  /// e.g. "Prescription" / "Dose" / "Medicine" / "User".
  resourceType String
  resourceId   String?
  ip           String?
  userAgent    String?
  /// Non-PHI structured context only (counts, route, etc.). NEVER PHI values.
  metadata     Json?
  /// `hash` of the previous row, forming the tamper-evident chain. Null for the
  /// very first row.
  prevHash     String?
  /// sha256(prevHash + canonical(entry)) for this row.
  hash         String
  createdAt    DateTime @default(now())

  /// FK is nullable + ON DELETE SET NULL: deleting a user must NOT delete or
  /// cascade-destroy their audit history (the trail outlives the actor).
  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([resourceType])
  @@index([createdAt])
}

/// Reminder + notification engine response log (GTM-537).
///
/// One row per reminder lifecycle EVENT for a dose: the reminder was delivered,
/// the user opened / snoozed / dismissed it, or the dose was actioned
/// (taken/skipped) FROM the reminder. This is the trigger of the dose-event data
/// pipeline (reminder -> open/snooze/dismiss -> action), so field names are kept
/// stable and aligned with the dose schema (`doseId`, `userId`, `scheduledFor`).
///
/// PHI-safety: this table stores NO free-text PHI (no mood/note/medication
/// names). Only structured event types + timestamps + non-PHI metadata, so the
/// analytics stream cannot leak PHI.
model ReminderResponseEvent {
  id     String @id @default(cuid())
  /// The session user the reminder belongs to (A2 / better-auth). Keyed so the
  /// pipeline can attribute every event to a user.
  userId String
  /// The dose this reminder is for. Nullable + ON DELETE SET NULL so deleting a
  /// dose does not destroy the historical response events (they outlive the dose
  /// for analytics), mirroring the AuditLog/actor pattern.
  doseId String?

  /// DELIVERED | OPENED | SNOOZED | DISMISSED | ACTIONED. Stored as a string for
  /// forward-compatibility (new event types need no migration).
  eventType String

  /// When the reminder was originally scheduled to fire (copied from the dose so
  /// the event is self-contained even if the dose is later deleted).
  scheduledFor DateTime?
  /// When this event actually happened on-device (client clock).
  occurredAt   DateTime  @default(now())

  /// For SNOOZED: how many minutes the user snoozed by.
  snoozeMinutes Int?
  /// Milliseconds from delivery to the user's action (open/snooze/dismiss/
  /// action) — the "time-to-action" metric for the pipeline. Null for DELIVERED.
  timeToActionMs Int?

  /// How the reminder was delivered: LOCAL (flutter_local_notifications) or PUSH
  /// (FCM/APNs). PUSH is scaffolded; LOCAL is the live path.
  channel String @default("LOCAL")

  /// Non-PHI structured context only (e.g. platform, app version). NEVER PHI.
  metadata Json?

  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  dose Dose? @relation(fields: [doseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([doseId])
  @@index([eventType])
  @@index([scheduledFor])
}

/// A push-notification token for one user device (GTM-537).
///
/// SCAFFOLD: stored so the backend CAN target FCM/APNs, but SENDING push is not
/// implemented here (requires a Firebase project + APNs cert — flagged for the
/// maintainer). The mobile app registers its token after auth; local
/// notifications are the live delivery path today.
model PushToken {
  id       String @id @default(cuid())
  userId   String
  /// The FCM registration token / APNs device token.
  token    String @unique
  /// "fcm" | "apns" — which push service the token belongs to.
  platform String
  /// Optional stable device identifier so a device can refresh its token.
  deviceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Refill lifecycle event log (GTM-541).
///
/// One row per refill action a user (or the app on their behalf) takes for a
/// prescription: the refill was REQUESTED, COMPLETED (picked up / dispensed),
/// or DELAYED. Keyed to the session user (A2 / better-auth) and the
/// prescription, this feeds refill-adherence metrics ("did the user refill on
/// time?") and is the seam a real pharmacy auto-refill provider would write to.
///
/// PHI-safety: stores NO free-text PHI (no medication names / notes beyond a
/// short structured outcome). Only ids + event types + timestamps + non-PHI
/// metadata, mirroring ReminderResponseEvent.
model RefillEvent {
  id     String @id @default(cuid())
  /// The session user the refill belongs to. Keyed so refill-adherence can be
  /// attributed per user.
  userId String
  /// The prescription being refilled. Nullable + ON DELETE SET NULL so deleting
  /// a prescription does not destroy refill history (it outlives the Rx for
  /// adherence analytics), mirroring the ReminderResponseEvent/Dose pattern.
  prescriptionId String?

  /// REQUESTED | COMPLETED | DELAYED. Stored as a string for forward-
  /// compatibility (new event types need no migration).
  eventType String

  /// Optional short, NON-PHI outcome code for the event (e.g. "auto",
  /// "manual", "out_of_stock", "insurance_hold"). NEVER free-text PHI.
  outcome String?

  /// The refill-due date this event relates to (copied so the event is
  /// self-contained even if the Rx is later deleted / re-projected).
  refillDueDate DateTime?
  /// When this event actually happened (client clock; defaults to now()).
  occurredAt    DateTime  @default(now())

  /// How the refill was initiated: MANUAL (user tapped) or AUTO (pharmacy
  /// auto-refill provider). AUTO is the STUB seam — no real provider today.
  channel String @default("MANUAL")

  /// Non-PHI structured context only (e.g. daysLeft at request, remainingSource).
  /// NEVER PHI.
  metadata Json?

  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescription Prescription? @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([prescriptionId])
  @@index([eventType])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@map("verifications")
}
