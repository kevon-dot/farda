// Prisma schema for better-auth with phone number authentication
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(cuid())
  email               String?  @unique
  name                String?
  image               String?
  phoneNumber         String?  @unique
  phoneNumberVerified Boolean  @default(false)
  emailVerified       Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  prescriptions Prescription[]
  doses         Dose[]
  auditLogs     AuditLog[]
}

model Prescription {
  id                   String    @id @default(cuid())
  userId               String
  deviceId             String?   @unique // The vial ID from the external API
  rxNumber             String?
  storeNumber          String?
  pharmacyOrDoctorName String?
  contactDetails       String?
  dateFilled           DateTime?
  dateExpired          DateTime?
  address              String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  doses     Dose[]
  medicines Medicine[]

  @@index([userId])
}

model Medicine {
  id                 String   @id @default(cuid())
  prescriptionId     String
  medicineName       String
  genericName        String?
  dosageInstructions String?
  strength           String?
  qty                String?
  frequency          String?
  refillsInfo        String?
  sideEffects        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
}

model Dose {
  id             String    @id @default(cuid())
  prescriptionId String
  userId         String
  scheduledFor   DateTime
  takenAt        DateTime?
  mood           String?
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prescriptionId])
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  type                 String
  provider             String
  providerAccountId    String
  accessToken          String?
  refreshToken         String?
  accessTokenExpiresAt DateTime?
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Tamper-evident, append-only audit trail of PHI access (HIPAA §164.312(b)).
///
/// APPEND-ONLY: there is intentionally NO `updatedAt`. Application code must
/// NEVER UPDATE or DELETE rows in this table. Tamper-evidence comes from a
/// per-row SHA-256 hash chain: `hash = sha256(prevHash + canonical(entry))`,
/// where `prevHash` is the `hash` of the immediately-preceding row. Any
/// after-the-fact edit/removal breaks the chain and is detectable.
///
/// This row must NEVER contain PHI values: only resource ids/types/actions and
/// request metadata, so the audit trail does not itself become a PHI leak.
model AuditLog {
  id           String   @id @default(cuid())
  /// The acting session user. Nullable so system/background actions can be
  /// recorded with no actor.
  actorUserId  String?
  /// READ / CREATE / UPDATE / DELETE.
  action       String
  /// e.g. "Prescription" / "Dose" / "Medicine" / "User".
  resourceType String
  resourceId   String?
  ip           String?
  userAgent    String?
  /// Non-PHI structured context only (counts, route, etc.). NEVER PHI values.
  metadata     Json?
  /// `hash` of the previous row, forming the tamper-evident chain. Null for the
  /// very first row.
  prevHash     String?
  /// sha256(prevHash + canonical(entry)) for this row.
  hash         String
  createdAt    DateTime @default(now())

  /// FK is nullable + ON DELETE SET NULL: deleting a user must NOT delete or
  /// cascade-destroy their audit history (the trail outlives the actor).
  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([resourceType])
  @@index([createdAt])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@map("verifications")
}
