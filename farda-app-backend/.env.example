# Example environment file. Copy to the real filename and fill in values.
# Real .env files are gitignored and MUST NOT be committed.

PORT=8000
HOST=0.0.0.0

DISABLE_HELMET=false

# CORS allowlist: comma-separated list of allowed origins. No wildcard is used,
# so only these exact origins are permitted on authenticated/credentialed
# routes. Leave empty to disallow all cross-origin requests.
CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Billing is deferred until the model is decided (IAP for consumer subs /
# Stripe for web-enterprise). No billing env vars are wired up yet. (#34)

# Twilio configuration
TWILIO_ACCOUNT_SID="<twilio_account_sid>"
TWILIO_AUTH_TOKEN="<twilio_auth_token>"
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"
TWILIO_VERIFY_SERVICE_SID="<twilio_verify_service_sid>"

DATABASE_URL="<database_url>"

# better-auth (#7/#8/#9). BETTER_AUTH_SECRET signs/encrypts sessions and bearer
# tokens — generate a long random value (e.g. `openssl rand -base64 32`) and set
# a DIFFERENT secret per environment. Never commit a real secret.
BETTER_AUTH_SECRET=<better_auth_secret>
BETTER_AUTH_URL=https://your-host.example.com

OPENAI_API_KEY=<openai_api_key>

# Rate limiting (issue #10). All optional; safe defaults apply when unset.
# Set RATE_LIMIT_DISABLED=true to turn limiting off entirely (e.g. load tests).
# Windows are in milliseconds, *_MAX is the request count allowed per window.
RATE_LIMIT_DISABLED=false
# OTP request / verify / social login (keyed by IP + phone). Default: 10 / 15min
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
# OCR extraction endpoints (keyed by IP + user). Default: 20 / 15min
OCR_RATE_LIMIT_WINDOW_MS=900000
OCR_RATE_LIMIT_MAX=20

# 3-layer data store + de-identification (GTM-522).
# DEID_SALT is the one-way salt used to derive the pseudonymous subject key
# (sha256(DEID_SALT + userId)) for the de-identified layer. Generate a long
# random value (e.g. `openssl rand -base64 32`), keep it SECRET, and use a
# DIFFERENT salt per environment. The de-id transform fails closed when unset.
# It is NEVER stored in the de-identified layer (no reverse mapping).
DEID_SALT=<deid_salt>

# Admin allowlist (comma-separated better-auth user ids) for the deny-by-default
# enterprise analytics export routes (/api/analytics/*). Empty = no admins, so
# the export is locked down until an operator opts an id in.
ADMIN_USER_IDS=
