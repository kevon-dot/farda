# Example environment file. Copy to the real filename and fill in values.
# Real .env files are gitignored and MUST NOT be committed.

PORT=8000
HOST=0.0.0.0

DISABLE_HELMET=false

# Stripe configuration
STRIPE_SECRET_KEY="<stripe_secret_key>"
STRIPE_SUCCESS_URL="https://your-host.example.com"
STRIPE_CANCEL_URL="https://your-host.example.com"

# Twilio configuration
TWILIO_ACCOUNT_SID="<twilio_account_sid>"
TWILIO_AUTH_TOKEN="<twilio_auth_token>"
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"
TWILIO_VERIFY_SERVICE_SID="<twilio_verify_service_sid>"

DATABASE_URL="<database_url>"

BETTER_AUTH_URL=https://your-host.example.com

OPENAI_API_KEY=<openai_api_key>
