{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@src/*": [
        "src/*"
      ]
    },
    "useUnknownInCatchVariables": false,
    "types": [
      "vitest/globals"
    ]
  },
  "ts-node": {
    "swc": true,
    "require": [
      "tsconfig-paths/register",
      "dotenv/config"
    ],
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts",
    "vitest.config.mts",
    "src/types/express.d.ts"
  ],
  "exclude": [
    "src/public/*"
  ]
}